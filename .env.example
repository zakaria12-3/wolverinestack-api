# ============================================================
# WOLVERINE STACK — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (Neon PostgreSQL) ---
# From your Neon dashboard: Settings → Connection Details
DB_URL=jdbc:postgresql://ep-floral-water-aul7kbkz.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_EjXucAFZW3T1

# --- JWT ---
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-256-bit-secret-key-change-this-in-production

# --- App Config ---
# After Render deployment, set this to your Render URL (e.g., https://wolverinestack-api.onrender.com)
APP_BASE_URL=http://localhost:8027

# Render sets PORT automatically; this default is for local dev
PORT=8027

# --- CORS ---
# Comma-separated list of allowed origins (for Render deployments)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:4200,http://127.0.0.1:4200,https://*.onrender.com,https://*.vercel.app

# --- AI Features ---
# Required for AI workout suggestions, meal plans, and goal recommendations
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Email (Optional) ---
# Brevo (formerly Sendinblue) for verification emails, password reset, daily tips
# Get your key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# Support email address shown in email templates
SUPPORT_EMAIL=admin@wolverinestack.com
