# ============================================================
# WOLVERINE STACK — Backend Environment Variables
# Copy this file to .env and fill in your values
# These are PLACEHOLDERS — actual keys are in the Render dashboard
# ============================================================

# --- Database (Neon PostgreSQL) ---
DB_URL=jdbc:postgresql://ep-floral-water-aul7kbkz.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_EjXucAFZW3T1

# --- JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))") ---
JWT_SECRET_KEY=your-256-bit-secret-key-here

# --- App Config ---
# After Render deployment, set APP_BASE_URL to your Render URL
APP_BASE_URL=http://localhost:8027
PORT=8027

# --- CORS ---
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:4200,http://127.0.0.1:4200,https://*.onrender.com,https://*.vercel.app

# --- AI (Groq) ---
GROQ_API_KEY=your-groq-api-key-here

# --- Email (Brevo) ---
BREVO_API_KEY=your-brevo-api-key-here
SUPPORT_EMAIL=admin@wolverinestack.com
